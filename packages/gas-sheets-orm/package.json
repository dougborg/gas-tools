{
  "name": "@dougborg/gas-sheets-orm",
  "version": "0.1.0",
  "description": "Type-safe sheet-as-database ORM for Google Apps Script: schema registry, repository pattern, domain models, validation.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./inputSanitizer": {
      "types": "./src/inputSanitizer.ts",
      "default": "./src/inputSanitizer.ts"
    },
    "./sheetMetadata": {
      "types": "./src/sheetMetadata.ts",
      "default": "./src/sheetMetadata.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "google-apps-script",
    "gas",
    "google-sheets",
    "orm",
    "typescript"
  ],
  "author": "Doug Borg <doug@spotbikes.com>",
  "license": "MIT",
  "peerDependencies": {
    "@types/google-apps-script": "^1.0.0 || ^2.0.0"
  },
  "dependencies": {
    "@dougborg/gas-utils": "*"
  },
  "devDependencies": {
    "@types/google-apps-script": "^2.0.0",
    "typescript": "^6.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dougborg/build-queue-scripts.git",
    "directory": "packages/gas-sheets-orm"
  }
}
