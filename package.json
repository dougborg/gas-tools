{
  "name": "@dougborg/gas-tools",
  "private": true,
  "version": "0.0.0",
  "description": "Monorepo for @dougborg Google Apps Script tooling packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit && npm run typecheck --workspaces --if-present",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality": "npm run typecheck && npm run lint && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/google-apps-script": "^2.0.0",
    "@types/node": "^24.3.0",
    "@vitest/coverage-v8": "^4.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  },
  "overrides": {
    "typescript": "$typescript"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dougborg/gas-tools.git"
  },
  "author": "Doug Borg <doug@spotbikes.com>",
  "license": "MIT",
  "volta": {
    "node": "22.22.0",
    "npm": "11.12.1"
  }
}
